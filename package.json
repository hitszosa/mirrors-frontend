{
  "name": "mirrors-frontend",
  "private": true,
  "scripts": {
    "build": "bun run mock:clean && astro build",
    "build:mock": "bun run mock:sync && astro build && bun run mock:clean",
    "dev": "bun run mock:sync && astro dev",
    "preview": "astro preview",
    "prepare": "husky",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "mock:sync": "bun scripts/sync-mock.mjs",
    "mock:clean": "bun scripts/clean-mock.mjs"
  },
  "lint-staged": {
    "*.{astro,css,js,json,md,mjs,ts,vue}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts,vue}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/vue": "^6.0.1",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "astro": "^6.2.1",
    "astro-icon": "^1.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-vue": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.99.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.7"
  },
  "dependencies": {
    "@hitszosa/ui": "^0.1.2",
    "@iconify-json/icon-park-outline": "^1.2.4",
    "@iconify/json": "^2.2.469",
    "@iconify/vue": "^5.0.0",
    "dayjs": "^1.11.20",
    "pinia": "^2.3.1",
    "vue": "^3.5.33"
  },
  "type": "module"
}
