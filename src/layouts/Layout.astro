---
import '../styles/global.css'
import Footer from '@components/Footer.astro'
import Navbar from '@components/Navbar.astro'

interface Props {
  title?: string
}

const { title = 'HITSZ OSA Mirrors' } = Astro.props
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="bg-page-bg text-page-fg">
    <div class="bg-page-bg">
      <div class="flex w-full flex-col text-page-fg">
        <div class="fixed top-0 left-0 z-50 w-full">
          <Navbar titleName="HITSZ OSA Mirrors" currentPath={currentPath}>
            <img slot="logo" class="h-full w-full" src="/images/logo.svg" alt="" />
          </Navbar>
        </div>
        <div class="flex min-h-screen flex-col justify-between bg-inherit px-6 pt-28 md:px-12 md:pt-16">
          <main class="mx-auto flex w-full justify-around py-12">
            <slot />
          </main>
          <Footer class="mt-6" />
        </div>
      </div>
    </div>
  </body>
</html>
