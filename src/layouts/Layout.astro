---
import '../styles/global.css'
import Footer from '../../components/Footer.vue'
import Navbar from '../../components/Navbar.vue'

interface Props {
  title?: string
}

const { title = 'HITSZ OSA Mirrors' } = Astro.props
const currentPath = Astro.url.pathname
const themeInitScript = `(function(){const key='nuxt-color-mode';const stored=localStorage.getItem(key);const theme=stored==='light'||stored==='dark'||stored==='system'?stored:'system';const prefersDark=window.matchMedia('(prefers-color-scheme: dark)').matches;const isDark=theme==='dark'||(theme==='system'&&prefersDark);document.documentElement.classList.toggle('dark',isDark);document.documentElement.style.colorScheme=isDark?'dark':'light'})()`
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>{themeInitScript}</script>
  </head>
  <body class="dark:bg-gray-900">
    <div class="dark:bg-gray-900">
      <div class="flex w-full flex-col text-slate-800 dark:text-slate-200">
        <div class="fixed top-0 left-0 z-50 w-full">
          <Navbar client:load titleName="HITSZ OSA Mirrors" currentPath={currentPath}>
            <img slot="logo" class="h-full w-full" src="/images/logo.svg" alt="" />
          </Navbar>
        </div>
        <div class="flex flex-col justify-between min-h-screen bg-inherit pt-28 px-6 md:pt-16 md:px-12">
          <main class="mx-auto flex w-full justify-around py-12">
            <slot />
          </main>
          <Footer />
        </div>
      </div>
    </div>
  </body>
</html>
