---
import { getCollection } from 'astro:content'
import Layout from '../layouts/Layout.astro'
import MirrorList from '../../components/index/MirrorList/MirrorList.vue'
import DownloadWidget from '../../components/index/DownloadWidget/DownloadWidget.vue'
import { sortNewsByDateDesc, toArticleDigest } from '../lib/news'

const news = sortNewsByDateDesc(await getCollection('news')).map(toArticleDigest).slice(0, 3)

const formatDate = (value: string) => {
  return new Intl.DateTimeFormat('zh-CN', {
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(value))
}
---

<Layout>
  <div class="flex w-full max-w-screen-xl min-w-0 flex-col space-y-12 md:flex-row md:space-x-12 md:space-y-0 md:items-start">
    <div class="flex min-w-0 grow flex-col space-y-4">
      <MirrorList client:load />
    </div>
    <div class="flex min-w-0 flex-col p-7 space-y-10 h-min bg-slate-50 dark:bg-gray-800 rounded-xl md:min-w-[20em] md:w-[32vw] md:max-w-[30em]">
      <section>
        <DownloadWidget client:load />
      </section>
      <section>
        <h2 class="text-2xl font-medium">Recent News</h2>
        <ul class="mt-4 space-y-2 list-none list-inside">
          {
            news.map((item) => (
              <li class="flex items-center justify-between gap-4">
                <a
                  href={item._path}
                  class="min-w-0 truncate transition-colors relative inline-block z-10 decoration-dotted underline-offset-4 hocus:underline hover:cursor-pointer"
                >
                  {item.title}
                </a>
                <span class="shrink-0 text-sm text-slate-500 dark:text-slate-400">
                  {formatDate(item.date)}
                </span>
              </li>
            ))
          }
        </ul>
        <a
          href="/news"
          class="mt-4 flex min-h-10 w-full items-center justify-center rounded-xl bg-white px-4 text-base font-medium text-slate-700 shadow-sm ring-1 ring-slate-200 transition-colors hocus:bg-slate-50 dark:bg-slate-900 dark:text-slate-100 dark:ring-slate-700 dark:hocus:bg-slate-800"
        >
          Read More
        </a>
      </section>
    </div>
  </div>
</Layout>
