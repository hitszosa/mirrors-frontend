---
import { getCollection } from 'astro:content'
import Layout from '../layouts/Layout.astro'
import MirrorList from '../../components/index/MirrorList/MirrorList.vue'
import DownloadWidget from '../../components/index/DownloadWidget/DownloadWidget.vue'
import NewsWidget from '../../components/index/NewsWidget/NewsWidget.vue'
import { sortNewsByDateDesc, toArticleDigest } from '../lib/news'

const news = sortNewsByDateDesc(await getCollection('news')).map(toArticleDigest).slice(0, 3)
---

<Layout>
  <div class="flex w-full max-w-screen-xl flex-col space-y-12 md:flex-row md:space-x-12 md:space-y-0 md:items-start">
    <div class="flex flex-col space-y-4 grow">
      <MirrorList client:load />
    </div>
    <div class="flex flex-col p-7 space-y-10 h-min bg-slate-50 dark:bg-gray-800 rounded-xl min-w-[20em] md:w-[32vw] md:max-w-[30em]">
      <section>
        <DownloadWidget client:load />
      </section>
      <section>
        <NewsWidget client:load digests={news} />
      </section>
    </div>
  </div>
</Layout>
