---
import Layout from '../layouts/Layout.astro'
---

<Layout>
  <div class="flex w-full max-w-screen-xl min-w-0 flex-col space-y-12 md:flex-row md:space-x-12 md:space-y-0 md:items-start">
    <div class="flex min-w-0 grow flex-col space-y-4">
      <section class="rounded-xl bg-slate-50 p-7 dark:bg-gray-800">
        <h1 class="text-2xl font-semibold">HITSZ OSA Mirrors</h1>
        <p class="mt-3 text-slate-600 dark:text-slate-300">
          镜像列表将在后续迁移 Vue 组件时接入。
        </p>
      </section>
    </div>
    <div class="flex min-w-0 flex-col p-7 space-y-10 h-min bg-slate-50 dark:bg-gray-800 rounded-xl md:min-w-[20em] md:w-[32vw] md:max-w-[30em]">
      <section>
        <h2 class="text-lg font-semibold">下载配置</h2>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
          下载小组件占位内容。
        </p>
      </section>
      <section>
        <h2 class="text-lg font-semibold">最新消息</h2>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
          新闻小组件占位内容。
        </p>
      </section>
    </div>
  </div>
</Layout>
